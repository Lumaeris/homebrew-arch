pkgname=brew-proxy
pkgver=0.3.2 # renovate: datasource=forgejo-releases depName=HastD/brew-proxy registryUrl=https://codeberg.org/
pkgrel=1
pkgdesc='DBus-activated proxy service for a more secure Homebrew setup on Linux'
arch=('x86_64')
url=https://codeberg.org/HastD/$pkgname
license=('Apache-2.0' 'CC0-1.0' 'MIT')
makedepends=('meson' 'cargo' 'rust')
install=${pkgname}.install
source=("https://codeberg.org/HastD/$pkgname/archive/v$pkgver.zip"
        40-brew-proxy.preset)
sha512sums=('447944f19c9b8542680bb3abd2cae7847f6b8fb44a58874579837f5000d495930dc3dd5dd923a4dc094d76260c7f3d587503f12e4f9a748297a64ca9a537232e'
            '5b0f5a68e9aec79edf36973a835cb88e33709f3b48641c79e521fd8c2cc0bdd442ab41acfc61d0ec6f505be6bfe4b9be33f47ee29885acdc7941a2255ab88012')

build() {
	meson setup build -Dprefix=/usr -Dselinux=disabled "${srcdir}/$pkgname"
	meson compile -C build
}

package() {
	DESTDIR="${pkgdir}" meson install -C build
	install -Dm0644 "40-brew-proxy.preset" -t "${pkgdir}/usr/lib/systemd/system-preset"
}
